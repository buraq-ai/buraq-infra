# GitHub Container Registry
GITHUB_REPOSITORY=your-github-org/buraq-ai
IMAGE_TAG=latest

# Database
DB_NAME=buraqdb
DB_USERNAME=buraquser
DB_PASSWORD=change_me

# JWT Secret (use a strong random string)
JWT_SECRET=change_me_to_a_random_64_char_string

# Email (SMTP credentials for notifications)
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=change_me

# OpenAI (leave empty if using Ollama)
OPENAI_API_KEY=

# Internal service communication key
INTERNAL_SERVICE_KEY=change_me_to_a_random_string

# LLM Provider (ollama or openai)
LLM_PROVIDER=ollama